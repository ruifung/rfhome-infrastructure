# SSHD Configuration (Baseline compliant)
Port 2222
Protocol 2
HostKey /etc/ssh/ssh_host_ed25519_key
HostKey /etc/ssh/ssh_host_rsa_key
HostKey /etc/ssh/ssh_host_ecdsa_key

# Logging
SyslogFacility AUTH
LogLevel INFO

# Authentication
PermitRootLogin no
PubkeyAuthentication yes
AuthorizedKeysFile .ssh/authorized_keys
PasswordAuthentication no
ChallengeResponseAuthentication no

# Note: ChrootDirectory is not used here because it requires CAP_SYS_CHROOT
# and doesn't support easy bind-mounts in Baseline.
# We use PRoot in the user's shell instead.

Match User openclaw
    ForceCommand /usr/local/bin/openclaw-shell
    AllowTcpForwarding yes
    X11Forwarding no
